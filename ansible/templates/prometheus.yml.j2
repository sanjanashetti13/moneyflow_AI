global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    monitor: 'money-flow-monitor'

# Alertmanager configuration (optional)
alerting:
  alertmanagers:
    - static_configs:
        - targets: []

# Load rules once and periodically evaluate them
rule_files:
  # - "alert_rules.yml"

# Scrape configurations
scrape_configs:
  # Prometheus itself
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']
        labels:
          instance: 'prometheus'

  # Node Exporter - System Metrics
  - job_name: 'node-exporter'
    static_configs:
      - targets: ['node-exporter:9100']
        labels:
          instance: 'ubuntu-server'

  # cAdvisor - Container Metrics
  - job_name: 'cadvisor'
    static_configs:
      - targets: ['cadvisor:8080']
        labels:
          instance: 'docker-containers'

  # Money Flow Backend (if you add metrics endpoint)
  # - job_name: 'money-flow-backend'
  #   static_configs:
  #     - targets: ['{{ server_ip }}:5000']
  #       labels:
  #         instance: 'money-flow-app'
